# Copy to docker/usr/.env and fill before deploying
NODE_ENV=production
STORAGE_BACKEND=simple  # 'simple' for local/test, 'idiostasis' for SecretVM production
DB_PATH=/data/panthers.db
VAULT_KEY_HEX=          # only required when STORAGE_BACKEND=idiostasis — generate with: openssl rand -hex 64
SOLANA_RPC_URL=         # e.g. https://api.mainnet-beta.solana.com or a Helius RPC endpoint
HELIUS_API_KEY=         # from helius.dev — used for USDC websocket monitor
TELEGRAM_BOT_TOKEN=     # from @BotFather
TELEGRAM_GROUP_CHAT_ID= # numeric Telegram group chat ID
SECRET_AI_API_KEY=      # from Secret AI dashboard
SECRET_AI_BASE_URL=https://ai.api.scrt.network
SECRET_AI_MODEL=deepseek-r1:70b
BIRDEYE_API_KEY=        # from birdeye.so
FEE_PCT_ON_BURN=0.02    # flat percentage withheld on NFT burn withdrawal
PUBLIC_CACHE_PATH=/data/public-cache.json
PUBLIC_PORT=3000
