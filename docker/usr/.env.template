# ============================================================
# Panthers Fund Agent — Environment Configuration
# ============================================================
#
# FIRST BOOT: fill in all values. The agent seeds them into
# its encrypted database automatically. After first boot,
# only the BOOT-CRITICAL vars below are required.
#
# Idiostasis replicates the database to guardian nodes so
# the agent can recover all config after succession with
# zero human intervention.
# ============================================================

# BOOT-CRITICAL — always required (cannot be stored in DB)
STORAGE_BACKEND=simple       # 'simple' for local/test | 'idiostasis' for production
DB_PATH=/data/panthers.db
VAULT_KEY_HEX=               # required only when STORAGE_BACKEND=idiostasis

# FIRST BOOT ONLY — seeded to DB on first run, ignored after
NODE_ENV=production
DEV_MODE=false

SECRET_AI_API_KEY=           # from Secret AI dashboard
SECRET_AI_BASE_URL=https://secretai-rytn.scrtlabs.com:21434
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_GROUP_CHAT_ID=      # numeric Telegram group chat ID

# Solana RPC — a single URL covers everything including websocket monitor
# Helius format (recommended): https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Websocket is automatically derived: wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Public fallback (no USDC monitor): https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=

BIRDEYE_API_KEY=             # from birdeye.so
COINGECKO_API_KEY=           # from coingecko.com
PUBLIC_PORT=3000
PUBLIC_CACHE_PATH=/data/public-cache.json
FEE_PCT_ON_BURN=0.02
GROUP_ACTIVITY_INTERVAL_MS=1800000

# NOTE: LLM model routing is seeded to DB with defaults automatically.
# To update models the agent updates its own DB — no redeploy needed.
